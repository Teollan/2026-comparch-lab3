// Структура віртуальної адреси:  [ segment : 12 ][ page : 10 ][ offset : 10 ]
// Структура фізичної адреси:     [ frame : 22                ][ offset : 10 ]

// [0][0][42] -> кадр 16, в пам'яті
1B 01 00 00 00 2A   // MOV R1, [0x0000002A] -> [0x0000402A]

// [1][0][256] -> кадр 32, в пам'яті
04 34 00 10 01 00   // ADD R3, R4, [0x00100100] -> [0x00008100]

// [1][1][85] -> сторінка вивантажена
0B 05 00 10 04 55   // SUB R5, [0x00100455] -> вивантажена сторінка

// [2][123][0] -> стор. 123 за межами 4 сторінок сегмента
1B 16 00 21 EC 00   // MOV [0x0021EC00], R6 -> відсутня сторінка

// [42][0][0] -> сегмента 42 немає в таблиці сегментів
1B 07 02 A0 00 00   // MOV R7, [0x02A00000] -> відсутній сегмент

// [3][0][171] -> кадр 1023, в пам'яті
0B 08 00 30 00 AB   // SUB R8, [0x003000AB] -> [0x000FFCAB]
