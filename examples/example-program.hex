// Variant 6 - segment-paged virtual memory, memory-access instructions only.
//
// Virtual address layout (32 bits):  [ segment : 12 ][ page : 10 ][ offset : 10 ]
// Physical address:                  ( frame << 10 ) | offset
//
// Run from the project root:
//   ./build/app -x -i examples/example-program.hex -s examples/example-segments.csv
//
// Each line below lists: encoding  // disassembly  -> expected physical / error

// (2) MOV <reg>, <addr>   seg 0 / page 0 / off 42 -> frame 16, resident
1B 01 00 00 00 2A   // MOV R1, [0x0000002A]        -> [0x0000402A]

// (7) ADD <reg>, <reg>, <addr>   seg 1 / page 0 / off 256 -> frame 32, resident
04 34 00 10 01 00   // ADD R3, R4, [0x00100100]    -> [0x00008100]

// (9) SUB <reg>, <addr>   seg 1 / page 1 -> present flag 0 (paged out)
0B 05 00 10 04 55   // SUB R5, [0x00100455]        -> page fault

// (3) MOV <addr>, <reg>   seg 2 / page 4 -> past the segment's 4 pages
1B 16 00 20 10 00   // MOV [0x00201000], R6        -> unmapped page

// (2) MOV <reg>, <addr>   seg 5 -> no such segment in the segment table
1B 07 00 50 00 00   // MOV R7, [0x00500000]        -> unmapped segment

// (9) SUB <reg>, <addr>   seg 3 / page 0 / off 171 -> frame 1023, resident
0B 08 00 30 00 AB   // SUB R8, [0x003000AB]        -> [0x000FFCAB]
