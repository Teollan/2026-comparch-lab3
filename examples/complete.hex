// Повний набір інструкцій за варіантом

1B 01 00 00 00 42  // MOV R1, [0x00000042]        (2)
1B 12 00 00 00 42  // MOV [0x00000042], R2        (3)
03 01 23           // ADD R1, R2, R3              (6)
04 12 00 00 00 42  // ADD R1, R2, [0x00000042]    (7)
0A 12              // SUB R1, R2                  (8)
0B 01 00 00 00 42  // SUB R1, [0x00000042]        (9)
80 AF              // CMP R10, R15                (26)
1C 11 33 44        // MOV R1, 13124               (28)
1C 21 33 44 55 66  // MOV R1, 860116326           (29)
