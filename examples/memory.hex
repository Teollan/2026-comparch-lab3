// Інструкції доступу до пам'яті: MOV reg<->addr, SUB/ADD з адресою

1B 01 00 00 00 42  // MOV  R1, [0x00000042]               (2)
1B 12 DE AD BE EF  // MOV  [0xDEADBEEF], R2               (3)
0B 01 00 00 00 42  // SUB  R1, [0x00000042]               (9)
04 12 00 00 00 42  // ADD  R1, R2, [0x00000042]           (7)
